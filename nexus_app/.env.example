# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nexus_db
POSTGRES_USER=nexus_user
POSTGRES_PASSWORD=nexus_desarrollo_123

# SQLAlchemy Pool Configuration
SQLALCHEMY_POOL_SIZE=5
SQLALCHEMY_MAX_OVERFLOW=10
SQLALCHEMY_POOL_TIMEOUT=30

# Neo4j Configuration (Para Transacciones ACID)
NEO4J_HOST=neo4j
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexus_desarrollo_123
NEO4J_DATABASE=neo4j

# Neo4j Transactional Timeouts (segundos)
# Para operaciones ACID de múltiples etiquetas
NEO4J_CONNECTION_TIMEOUT=30
NEO4J_COMMAND_TIMEOUT=60

# FastAPI Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_DEBUG=false

#Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=1234

#SSL (opcional para desarrollo, obligatorio para producción)
DATABASE_SSL_MODE=disable # development: disable | production: require

# Entorno
ENVIRONMENT=development
LOG_LEVEL=DEBUG